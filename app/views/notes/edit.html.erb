<div class="breadcrumb">
  <%= link_to "Clients", clients_path %><span>/</span>
  <% if @note.matter.client %>
    <%= link_to @note.matter.client, @note.matter.client %><span>/</span>
  <% end %>
  <%= link_to @note.matter, @note.matter %><span>/</span> Edit
</div>

<div class="page-header">
  <h1>Edit Note</h1>
</div>

<div class="form-card">
  <%= form_with model: @note do |form| %>
    <%= form.label :body %>
    <%= form.text_area :body %>
    <div class="form-actions">
      <%= form.submit "Save Changes", class: "btn btn-primary" %>
      <%= link_to "Cancel", @note.matter, class: "btn btn-secondary" %>
    </div>
  <% end %>
</div>
