<% if client.errors.any? %>
  <div class="error-messages">
    <strong><%= pluralize(client.errors.count, "error") %> prevented this client from being saved:</strong>
    <ul>
      <% client.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<div class="form-group">
  <%= form.label :name %>
  <%= form.text_field :name, placeholder: "Full name or company" %>
</div>

<div class="form-group">
  <%= form.label :email %>
  <%= form.email_field :email, placeholder: "email@example.com" %>
</div>

<div class="form-group">
  <%= form.label :phone %>
  <%= form.text_field :phone, placeholder: "+61 4xx xxx xxx" %>
</div>

<div class="form-group">
  <%= form.label :address %>
  <%= form.text_area :address, placeholder: "Street, Suburb, State, Postcode" %>
</div>
