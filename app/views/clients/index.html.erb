<div class="page-header">
  <h1>Clients</h1>
  <%= link_to "New Client", new_client_path, class: "btn btn-primary" %>
</div>

<% if @clients.any? %>
  <table>
    <thead>
      <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Phone</th>
        <th>Matters</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @clients.each do |client| %>
        <tr>
          <td><%= link_to client.name, client %></td>
          <td><%= client.email.presence || "—" %></td>
          <td><%= client.phone.presence || "—" %></td>
          <td><%= client.matters.size %></td>
          <td>
            <div class="actions">
              <%= link_to "View", client, class: "btn btn-secondary btn-sm" %>
              <%= link_to "Edit", edit_client_path(client), class: "btn btn-secondary btn-sm" %>
              <%= button_to "Delete", client, method: :delete, class: "btn btn-danger btn-sm", form: { data: { turbo_confirm: "Delete #{client.name}?" } } %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="empty">No clients yet. <%= link_to "Add your first client", new_client_path %>.</p>
<% end %>
