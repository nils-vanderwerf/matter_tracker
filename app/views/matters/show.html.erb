<div class="breadcrumb">
  <%= link_to "Clients", clients_path %><span>/</span>
  <% if @client %>
    <%= link_to @client.name, @client %><span>/</span>
  <% end %>
  <%= @matter.title %>
</div>

<div class="page-header">
  <div>
    <h1><%= @matter.title %></h1>
    <% if @matter.closed? %>
      <p style="color: #888; margin: 0; font-size: 0.9em;">This case has been closed.</p>
    <% end %>
  </div>
  <div class="actions">
    <% if @matter.closed? %>
      <%= button_to "Reopen", reopen_matter_path(@matter), method: :patch, class: "btn btn-secondary", form: { onsubmit: "return confirm('Reopen this matter?')" } %>
    <% else %>
      <%= link_to "Edit", edit_matter_path(@matter), class: "btn btn-secondary" %>
      <%= button_to "Close Matter", close_matter_path(@matter), method: :patch, class: "btn btn-primary", form: { onsubmit: "return confirm('Close this matter?')" } %>
      <%= button_to "Delete", @matter, method: :delete, class: "btn btn-danger", form: { onsubmit: "return confirm('Delete this matter?')" } %>
    <% end %>
  </div>
</div>

<div class="detail-card">
  <div class="detail-grid">
    <div class="detail-item">
      <label>Client</label>
      <p><%= @client ? link_to(@client.name, @client) : "—" %></p>
    </div>
    <div class="detail-item">
      <label>Type</label>
      <p><%= @matter.matter_type %></p>
    </div>
    <div class="detail-item">
      <label>Status</label>
      <p>
        <span class="badge badge-<%= @matter.status.downcase %>"><%= @matter.status %></span>
        <% if @last_status_change %>
          <span style="color: #888; font-size: 0.8em; margin-left: 0.4rem;">since <%= @last_status_change.created_at.strftime("%d %b %Y") %></span>
        <% end %>
      </p>
    </div>
    <div class="detail-item">
      <label>Due Date</label>
      <p><%= @matter.due_date&.strftime("%d %B %Y") || "—" %></p>
    </div>
    <div class="detail-item full">
      <label>Description</label>
      <p><%= @matter.description.presence || "—" %></p>
    </div>
  </div>
</div>

<div class="section-header">
  <h2>Status History</h2>
</div>
<div class="status-history">
  <% @matter.status_changes.order(created_at: :asc).each do |change| %>
    <div class="status-history-item">
      <span class="status-history-label"><%= change.status %></span>
      <span class="status-history-date"><%= change.created_at.strftime("%d %b %Y, %H:%M") %></span>
    </div>
  <% end %>
</div>

<div class="section-header">
  <h2>Tasks (<%= @tasks.count %>)</h2>
  <%= link_to "New Task", new_matter_task_path(@matter), class: "btn btn-primary btn-sm" %>
</div>

<% if @tasks.any? %>
  <table>
    <thead>
      <tr>
        <th>Title</th>
        <th>Priority</th>
        <th>Status</th>
        <th>Due Date</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @tasks.each do |task| %>
        <tr>
          <td><%= link_to task.title, task %></td>
          <td><span class="badge badge-<%= task.priority.downcase %>"><%= task.priority %></span></td>
          <td>
            <% css = task.status == "In Progress" ? "in-progress" : task.status.downcase %>
            <span class="badge badge-<%= css %>"><%= task.status %></span>
          </td>
          <td><%= task.due_date&.strftime("%d %b %Y") || "—" %></td>
          <td>
            <div class="actions">
              <%= link_to "View", task, class: "btn btn-secondary btn-sm" %>
              <%= link_to "Edit", edit_task_path(task), class: "btn btn-secondary btn-sm" %>
              <%= button_to "Delete", task, method: :delete, class: "btn btn-danger btn-sm", form: { style: "display: contents", onsubmit: "return confirm('Delete this task?')" } %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="empty">No tasks yet. <%= link_to "Add one", new_matter_task_path(@matter) %>.</p>
<% end %>

<!-- Notes section -->
<div class="section-header">
  <h2>Notes</h2>
</div>

<% @matter.notes.order(created_at: :desc).each do |note| %>
  <div class="detail-card">
  <div style="display: flex; justify-content: space-between; align-items: center;">
    <div>
      <p style="margin: 0;"><%= note.body %></p>
      <small><%= note.created_at.strftime("%d %b %Y, %H:%M") %></small>
    </div>
    <div class="actions" style="display: flex; align-items: center; gap: 8px;">
      <%= link_to "Edit", edit_note_path(note), class: "btn btn-secondary btn-sm" %>
      <%= button_to "Delete", note_path(note), method: :delete, class: "btn btn-danger btn-sm",
          form: {
            style: "display: contents;",
            onsubmit: "return confirm('Delete this note?')"
          } %>
    </div>
  </div>
</div>
<% end %>

<%= form_with model: [@matter, Note.new], class: "detail-card" do |form| %>
  <div class="form-group">
    <%= form.label :body, "Add a note" %>
    <%= form.text_area :body, placeholder: "Type your note here…" %>
  </div>
  <div class="form-actions">
    <%= form.submit "Add Note", class: "btn btn-primary" %>
  </div>
<% end %>