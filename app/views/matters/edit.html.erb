<div class="breadcrumb">
  <%= link_to "Clients", clients_path %><span>/</span>
  <% if @client %>
    <%= link_to @client.name, @client %><span>/</span>
  <% end %>
  <%= link_to @matter.title, @matter %><span>/</span> Edit
</div>

<div class="page-header">
  <h1>Edit Matter</h1>
</div>

<div class="form-card">
  <%= form_with model: @matter do |form| %>
    <%= render "form", form: form, matter: @matter %>
    <div class="form-actions">
      <%= form.submit "Save Changes", class: "btn btn-primary" %>
      <%= link_to "Cancel", @matter, class: "btn btn-secondary" %>
    </div>
  <% end %>
</div>
