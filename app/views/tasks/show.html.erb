<% matter = @task.matter %>
<% client = matter.client %>

<div class="breadcrumb">
  <%= link_to "Clients", clients_path %><span>/</span>
  <% if client %>
    <%= link_to client.name, client %><span>/</span>
  <% end %>
  <%= link_to matter.title, matter %><span>/</span>
  <%= @task.title %>
</div>

<div class="page-header">
  <div>
    <h1><%= @task.title %></h1>
    <% if @task.overdue? %>
      <p class="overdue-notice">
        <span class="badge badge-overdue">Overdue</span>
        was due <%= @task.due_date.strftime("%d %b %Y") %>
      </p>
    <% end %>
  </div>
  <div class="actions">
    <%= link_to "Edit", edit_task_path(@task), class: "btn btn-secondary" %>
    <%= button_to "Delete", @task, method: :delete, class: "btn btn-danger", form: { data: { turbo_confirm: "Delete this task?" } } %>
  </div>
</div>

<div class="detail-card">
  <div class="detail-grid">
    <div class="detail-item">
      <label>Matter</label>
      <p><%= link_to matter.title, matter %></p>
    </div>
    <div class="detail-item">
      <label>Priority</label>
      <p><span class="badge badge-<%= @task.priority.downcase %>"><%= @task.priority %></span></p>
    </div>
    <div class="detail-item">
      <label>Status</label>
      <% css = @task.status == "In Progress" ? "in-progress" : @task.status.downcase %>
      <p><span class="badge badge-<%= css %>"><%= @task.status %></span></p>
    </div>
    <div class="detail-item">
      <label>Due Date</label>
      <p <% if @task.overdue? %>style="color: #dc2626; font-weight: 500;"<% end %>>
        <%= @task.due_date&.strftime("%d %B %Y") || "—" %>
      </p>
    </div>
    <div class="detail-item full">
      <label>Description</label>
      <p><%= @task.description.presence || "—" %></p>
    </div>
  </div>
</div>

<%= link_to "← Back to Matter", matter, class: "btn btn-secondary" %>
